{
  "name": "veclite",
  "version": "0.1.0",
  "description": "Embedded, single-file, in-process vector database (Node.js binding).",
  "keywords": ["vector-database", "embeddings", "search", "embedded", "hnsw"],
  "license": "Apache-2.0",
  "repository": "https://github.com/hivellm/veclite",
  "main": "veclite.js",
  "types": "veclite.d.ts",
  "napi": {
    "name": "veclite",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-musl"
      ]
    }
  },
  "files": ["veclite.js", "veclite.d.ts", "index.js", "index.d.ts"],
  "optionalDependencies": {
    "veclite-darwin-arm64": "0.1.0",
    "veclite-darwin-x64": "0.1.0",
    "veclite-linux-arm64-gnu": "0.1.0",
    "veclite-linux-x64-gnu": "0.1.0",
    "veclite-linux-x64-musl": "0.1.0",
    "veclite-win32-x64-msvc": "0.1.0"
  },
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node --expose-gc --test \"__test__/*.test.mjs\""
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  }
}
