# Rulebook - ignore runtime data, keep specs and tasks
/.rulebook/*
!/.rulebook/specs/
!/.rulebook/tasks/
!/.rulebook/archive/
!/.rulebook/decisions/
!/.rulebook/knowledge/
!/.rulebook/learnings/
!/.rulebook/tasks/**/*.md
!/.rulebook/rulebook.json

# Patterns added by @hivellm/rulebook
# Added at: 2026-07-13T00:33:38.124Z

*.log
*.swo
*.swp
*~
.DS_Store
.cache/
.env
.env.*.local
.env.local
.idea/
.vscode/
Thumbs.db
logs/
temp/
tmp/

CLAUDE.local.md
.rulebook/backup/
.rulebook/handoff/_pending.md
.rulebook/handoff/.urgent

# Rust
# `target/` (no leading slash) matches the build dir at any depth, so the
# workspace root AND any excluded/standalone crate (e.g. crates/veclite-py)
# are covered without a per-crate .gitignore.
target/
**/*.rs.bk
*.pdb
# fastembed downloads pretrained ONNX models into a `.fastembed_cache/` in the
# working dir when the onnx tests run without an explicit cache dir (SPEC-005 §6).
.fastembed_cache/
docs/site/

# Python packaging build output (maturin/pip).
crates/veclite-py/dist/
